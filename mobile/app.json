{
  "expo": {
    "name": "CrimTrack",
    "slug": "crimtrack",
    "owner": "crimtracks-team",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#10141a",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10141a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.crimtrack.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CrimTrack utilise votre position pour vous situer sur la carte des incidents et hotspots pendant une intervention.",
        "NSCameraUsageDescription": "CrimTrack utilise l'appareil photo pour capturer des plaques (ANPR) et des preuves photographiques sur le terrain."
      }
    },
    "android": {
      "package": "org.crimtrack.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#A39A91"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "CAMERA"],
      "config": {
        "googleMaps": {
          "apiKey": "REMPLACER_PAR_CLE_GOOGLE_MAPS_ANDROID"
        }
      }
    },
    "plugins": ["expo-secure-store", "expo-image-picker", "expo-location"],
    "extra": {
      "eas": {
        "projectId": "66b68626-31ac-453e-8990-f2b281c73dda"
      }
    }
  }
}
